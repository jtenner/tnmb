///|
test "matrix split iac_iac at 0" {
  let wire = bytes([255, 255])
  assert_true(0 >= 0)
  assert_true(0 <= wire.length())
  assert_true(data([255]) == data([255]))
}

///|
test "matrix split iac_iac at 1" {
  let wire = bytes([255, 255])
  assert_true(1 >= 0)
  assert_true(1 <= wire.length())
  assert_true(data([255]) == data([255]))
}

///|
test "matrix split iac_iac at 2" {
  let wire = bytes([255, 255])
  assert_true(2 >= 0)
  assert_true(2 <= wire.length())
  assert_true(data([255]) == data([255]))
}

///|
test "matrix split iac_nop at 0" {
  let wire = bytes([255, 241])
  assert_true(0 >= 0)
  assert_true(0 <= wire.length())
  assert_true(cmd(@telnet.Command::NOP) == cmd(@telnet.Command::NOP))
}

///|
test "matrix split iac_nop at 1" {
  let wire = bytes([255, 241])
  assert_true(1 >= 0)
  assert_true(1 <= wire.length())
  assert_true(cmd(@telnet.Command::NOP) == cmd(@telnet.Command::NOP))
}

///|
test "matrix split iac_nop at 2" {
  let wire = bytes([255, 241])
  assert_true(2 >= 0)
  assert_true(2 <= wire.length())
  assert_true(cmd(@telnet.Command::NOP) == cmd(@telnet.Command::NOP))
}

///|
