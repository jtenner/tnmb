///|
test "matrix q no receives will with accept" {
  let transition = @telnet.NegotiationTransition::{
    before: option_state(1, @telnet.HalfState::No, @telnet.HalfState::No),
    input: neg_event(@telnet.NegotiationVerb::Will, 1),
    decision: @telnet.PolicyDecision::Accept,
    after: option_state(1, @telnet.HalfState::No, @telnet.HalfState::No),
    actions: [@telnet.NegotiationAction::NoAction],
  }
  assert_true(transition.before.option == opt(1))
  assert_true(transition.decision == @telnet.PolicyDecision::Accept)
}

///|
test "matrix q no receives will with reject" {
  let transition = @telnet.NegotiationTransition::{
    before: option_state(1, @telnet.HalfState::No, @telnet.HalfState::No),
    input: neg_event(@telnet.NegotiationVerb::Will, 1),
    decision: @telnet.PolicyDecision::Reject,
    after: option_state(1, @telnet.HalfState::No, @telnet.HalfState::No),
    actions: [@telnet.NegotiationAction::NoAction],
  }
  assert_true(transition.before.option == opt(1))
  assert_true(transition.decision == @telnet.PolicyDecision::Reject)
}

///|
test "matrix q no receives will with ignore" {
  let transition = @telnet.NegotiationTransition::{
    before: option_state(1, @telnet.HalfState::No, @telnet.HalfState::No),
    input: neg_event(@telnet.NegotiationVerb::Will, 1),
    decision: @telnet.PolicyDecision::Ignore,
    after: option_state(1, @telnet.HalfState::No, @telnet.HalfState::No),
    actions: [@telnet.NegotiationAction::NoAction],
  }
  assert_true(transition.before.option == opt(1))
  assert_true(transition.decision == @telnet.PolicyDecision::Ignore)
}

